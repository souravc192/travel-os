{
  "name": "@travel-os/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc --outDir dist",
    "start": "node dist/index.js",
    "migrate": "node scripts/run-migration.js src/migrations/001_initial_schema.sql",
    "seed": "node scripts/run-migration.js src/migrations/001b_seed.sql",
    "migrate:phase2": "node scripts/run-migration.js src/migrations/002_budget_alerts.sql",
    "migrate:phase3": "node scripts/run-migration.js src/migrations/003_phase3_overhaul.sql",
    "seed:phase3": "node scripts/run-migration.js src/migrations/003b_seed.sql",
    "migrate:phase4": "node scripts/run-migration.js src/migrations/004_phase4_bookings_policy.sql",
    "migrate:phase5a": "node scripts/run-migration.js src/migrations/005_phase5a_urgency_booking.sql",
    "migrate:phase5b": "node scripts/run-migration.js src/migrations/006_phase5b_multi_segment.sql",
    "migrate:phase5c": "node scripts/run-migration.js src/migrations/007_phase5c_reimbursement.sql",
    "migrate:all": "npm run migrate && npm run seed && npm run migrate:phase2 && npm run migrate:phase3 && npm run seed:phase3 && npm run migrate:phase4 && npm run migrate:phase5a && npm run migrate:phase5b && npm run migrate:phase5c",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@travel-os/shared-types": "*",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "exceljs": "^4.4.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
