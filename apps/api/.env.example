# ============================================================
# Travel OS API — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────
# Local (Docker Compose):
DATABASE_URL=postgresql://travel_os_user:travel_os_secret_dev@localhost:5432/travel_os

# Production (Railway / Supabase / Neon):
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Redis ─────────────────────────────────────────────────────
# Local (Docker Compose):
REDIS_URL=redis://:redis_secret_dev@localhost:6379

# Production (Railway Redis / Upstash):
# REDIS_URL=redis://:password@host:6379

# ── JWT Secrets (generate with: openssl rand -hex 64) ────────
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING_ACCESS
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING_REFRESH

# ── Cookie ────────────────────────────────────────────────────
COOKIE_SECRET=REPLACE_WITH_RANDOM_SECRET_STRING

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── File Storage (Cloudflare R2) ──────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=travel-os-invoices
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Email (Nodemailer / Resend) ───────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_your_api_key
EMAIL_FROM=noreply@your-domain.com

# ── ERP Webhook ───────────────────────────────────────────────
ERP_WEBHOOK_URL=https://your-erp.example.com/api/travel-sync
ERP_WEBHOOK_SECRET=your_erp_webhook_secret

# ── Scraper Proxy (Phase 5) ───────────────────────────────────
PROXY_LIST_URL=https://proxy.webshare.io/api/v2/proxy/list/?mode=direct
PROXY_API_KEY=your_proxy_api_key
